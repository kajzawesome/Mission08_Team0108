@model Mission__8___Group_8.Models.Task

@{
    ViewData["Title"] = "Delete Task";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">Delete Task</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Are you sure you want to delete this task?
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Task:</dt>
                        <dd class="col-sm-9">@Model.TaskName</dd>

                        <dt class="col-sm-3">Due Date:</dt>
                        <dd class="col-sm-9">@Model.DueDate?.ToString("MM/dd/yyyy")</dd>

                        <dt class="col-sm-3">Quadrant:</dt>
                        <dd class="col-sm-9">
                            @switch (Model.QuadrantId)
                            {
                                case 1:
                                    <span class="badge bg-danger">Quadrant I: Important / Urgent</span>
                                    break;
                                case 2:
                                    <span class="badge bg-success">Quadrant II: Important / Not Urgent</span>
                                    break;
                                case 3:
                                    <span class="badge bg-warning text-dark">Quadrant III: Not Important / Urgent</span>
                                    break;
                                case 4:
                                    <span class="badge bg-info">Quadrant IV: Not Important / Not Urgent</span>
                                    break;
                            }
                        </dd>

                        <dt class="col-sm-3">Category:</dt>
                        <dd class="col-sm-9">@Model.Category?.CategoryName</dd>

                        <dt class="col-sm-3">Completed:</dt>
                        <dd class="col-sm-9">@(Model.Completed ? "Yes" : "No")</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="TaskId" />
                        <div class="btn-group" role="group">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                            <a asp-action="Quadrants" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
