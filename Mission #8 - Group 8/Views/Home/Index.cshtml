@model IEnumerable<Mission__8___Group_8.Models.TaskItem>

@{
    ViewData["Title"] = "Task Quadrants";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h1 class="display-4">Task Management - Quadrants View</h1>
            <p class="lead">Organize your tasks using Stephen Covey's Time Management Matrix</p>
        </div>
    </div>

    <div class="row">
        <!-- Quadrant I: Important / Urgent -->
        <div class="col-12 col-md-6 mb-4">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Quadrant I: Important / Urgent</h4>
                    <small>Crises, Pressing Problems, Projects with Deadlines</small>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any(t => t.QuadrantId == 1 && !t.Completed))
                    {
                        <div class="list-group">
                            @foreach (var task in Model.Where(t => t.QuadrantId == 1 && !t.Completed))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@task.TaskName</h5>
                                        <small class="text-muted">@task.DueDate?.ToString("MM/dd/yyyy")</small>
                                    </div>
                                    <p class="mb-1">
                                        <span class="badge bg-secondary">@task.Category?.CategoryName</span>
                                    </p>
                                    <div class="btn-group btn-group-sm mt-2" role="group">
                                        <a asp-action="Update" asp-route-id="@task.TaskId" class="btn btn-warning">Update</a>
                                        <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-danger">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No tasks in this quadrant</p>
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant II: Important / Not Urgent -->
        <div class="col-12 col-md-6 mb-4">
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Quadrant II: Important / Not Urgent</h4>
                    <small>Relationship Building, Planning, Recreation</small>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any(t => t.QuadrantId == 2 && !t.Completed))
                    {
                        <div class="list-group">
                            @foreach (var task in Model.Where(t => t.QuadrantId == 2 && !t.Completed))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@task.TaskName</h5>
                                        <small class="text-muted">@task.DueDate?.ToString("MM/dd/yyyy")</small>
                                    </div>
                                    <p class="mb-1">
                                        <span class="badge bg-secondary">@task.Category?.CategoryName</span>
                                    </p>
                                    <div class="btn-group btn-group-sm mt-2" role="group">
                                        <a asp-action="Update" asp-route-id="@task.TaskId" class="btn btn-warning">Update</a>
                                        <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-danger">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No tasks in this quadrant</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Quadrant III: Not Important / Urgent -->
        <div class="col-12 col-md-6 mb-4">
            <div class="card border-warning">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Quadrant III: Not Important / Urgent</h4>
                    <small>Interruptions, Some Phone Calls, Some Mail, Some Reports</small>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any(t => t.QuadrantId == 3 && !t.Completed))
                    {
                        <div class="list-group">
                            @foreach (var task in Model.Where(t => t.QuadrantId == 3 && !t.Completed))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@task.TaskName</h5>
                                        <small class="text-muted">@task.DueDate?.ToString("MM/dd/yyyy")</small>
                                    </div>
                                    <p class="mb-1">
                                        <span class="badge bg-secondary">@task.Category?.CategoryName</span>
                                    </p>
                                    <div class="btn-group btn-group-sm mt-2" role="group">
                                        <a asp-action="Update" asp-route-id="@task.TaskId" class="btn btn-warning">Update</a>
                                        <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-danger">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No tasks in this quadrant</p>
                    }
                </div>
            </div>
        </div>

        <!-- Quadrant IV: Not Important / Not Urgent -->
        <div class="col-12 col-md-6 mb-4">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">Quadrant IV: Not Important / Not Urgent</h4>
                    <small>Busy Work, Some Phone Calls, Time Wasters</small>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any(t => t.QuadrantId == 4 && !t.Completed))
                    {
                        <div class="list-group">
                            @foreach (var task in Model.Where(t => t.QuadrantId == 4 && !t.Completed))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h5 class="mb-1">@task.TaskName</h5>
                                        <small class="text-muted">@task.DueDate?.ToString("MM/dd/yyyy")</small>
                                    </div>
                                    <p class="mb-1">
                                        <span class="badge bg-secondary">@task.Category?.CategoryName</span>
                                    </p>
                                    <div class="btn-group btn-group-sm mt-2" role="group">
                                        <a asp-action="Update" asp-route-id="@task.TaskId" class="btn btn-warning">Update</a>
                                        <a asp-action="Delete" asp-route-id="@task.TaskId" class="btn btn-danger">Delete</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No tasks in this quadrant</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        min-height: 300px;
    }
    .list-group-item {
        border-left: 4px solid;
    }
    .card.border-danger .list-group-item {
        border-left-color: #dc3545;
    }
    .card.border-success .list-group-item {
        border-left-color: #28a745;
    }
    .card.border-warning .list-group-item {
        border-left-color: #ffc107;
    }
    .card.border-info .list-group-item {
        border-left-color: #17a2b8;
    }
</style>
